# ─────────────────────────────────────────────────────────────────
# Environment variables – copy this file to .env and fill in values
# Never commit the actual .env file!
# ─────────────────────────────────────────────────────────────────

# Port the backend API listens on
PORT=3001

# SQLite database file path (relative to backend/)
DB_PATH=./data/ideas.db

# Allowed CORS origin (the URL where the frontend runs)
CORS_ORIGIN=http://localhost:5173

# OpenAI API key – used by AI helper scripts (optional)
OPENAI_API_KEY=sk-your-key-here

# Node environment: development | test | production
NODE_ENV=development
