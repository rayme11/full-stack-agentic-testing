{
  "folders": [
    {
      "name": "📚 Full-Stack Agentic Testing",
      "path": ".",
    },
    {
      "name": "🖥  Backend (Express + TypeScript + SQLite)",
      "path": "backend",
    },
    {
      "name": "🎨 Frontend (Vite + TypeScript + HTML)",
      "path": "frontend",
    },
    {
      "name": "🧪 Tests (Playwright + Cucumber BDD)",
      "path": "tests",
    },
    {
      "name": "📖 Docs (Step-by-Step Learning)",
      "path": "docs",
    },
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "typescript.preferences.quoteStyle": "double",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "typescript.suggest.autoImports": true,
    "editor.rulers": [100],
    "files.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/.git": false,
      "**/data/*.db": true,
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
    },
    "cucumberautocomplete.steps": ["tests/bdd/steps/*.ts"],
    "cucumberautocomplete.syncfeatures": "tests/bdd/features/*.feature",
    "playwright.reuseBrowser": false,
    "playwright.showTrace": true,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
      "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.js.map",
      "tsconfig.json": "tsconfig.*.json",
      "package.json": "package-lock.json, .npmrc",
    },
    "terminal.integrated.env.osx": {
      "NODE_OPTIONS": "--no-warnings=ExperimentalWarning",
    },
    "terminal.integrated.env.linux": {
      "NODE_OPTIONS": "--no-warnings=ExperimentalWarning",
    },
    "terminal.integrated.env.windows": {
      "NODE_OPTIONS": "--no-warnings=ExperimentalWarning",
    },
  },
  "extensions": {
    "recommendations": [
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "ms-playwright.playwright",
      "alexkrechik.cucumberautocomplete",
      "streetsidesoftware.code-spell-checker",
      "github.copilot",
      "github.copilot-chat",
      "ms-vscode.vscode-typescript-next",
      "eamodio.gitlens",
      "github.vscode-github-actions",
      "redhat.vscode-yaml",
      "alexcvzz.vscode-sqlite",
      "gruntfuggly.todo-tree",
    ],
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "▶ Start Backend (dev)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "npm",
        "runtimeArgs": ["run", "dev"],
        "cwd": "${workspaceFolder:🖥  Backend (Express + TypeScript + SQLite)}",
        "skipFiles": ["<node_internals>/**"],
        "console": "integratedTerminal",
      },
      {
        "name": "🧪 Debug Playwright Tests",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "npx",
        "runtimeArgs": ["playwright", "test", "--headed", "--debug"],
        "cwd": "${workspaceFolder:🧪 Tests (Playwright + Cucumber BDD)}",
        "skipFiles": ["<node_internals>/**"],
        "console": "integratedTerminal",
      },
    ],
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "1️⃣  Install All Dependencies",
        "type": "shell",
        "command": "npm install",
        "options": {
          "cwd": "${workspaceFolder:🖥  Backend (Express + TypeScript + SQLite)}",
        },
        "group": "build",
        "presentation": { "reveal": "always", "panel": "new" },
      },
      {
        "label": "2️⃣  Start Backend",
        "type": "shell",
        "command": "npm run dev",
        "options": {
          "cwd": "${workspaceFolder:🖥  Backend (Express + TypeScript + SQLite)}",
        },
        "group": "build",
        "isBackground": true,
        "presentation": { "reveal": "always", "panel": "new" },
        "problemMatcher": [],
      },
      {
        "label": "3️⃣  Start Frontend",
        "type": "shell",
        "command": "npm run dev",
        "options": {
          "cwd": "${workspaceFolder:🎨 Frontend (Vite + TypeScript + HTML)}",
        },
        "group": "build",
        "isBackground": true,
        "presentation": { "reveal": "always", "panel": "new" },
        "problemMatcher": [],
      },
      {
        "label": "4️⃣  Run API Tests",
        "type": "shell",
        "command": "npm run test:api",
        "options": {
          "cwd": "${workspaceFolder:🧪 Tests (Playwright + Cucumber BDD)}",
        },
        "group": "test",
        "presentation": { "reveal": "always", "panel": "new" },
      },
      {
        "label": "5️⃣  Run BDD Tests",
        "type": "shell",
        "command": "npm run test:bdd",
        "options": {
          "cwd": "${workspaceFolder:🧪 Tests (Playwright + Cucumber BDD)}",
        },
        "group": "test",
        "presentation": { "reveal": "always", "panel": "new" },
      },
      {
        "label": "6️⃣  Run E2E Tests",
        "type": "shell",
        "command": "npm run test:e2e",
        "options": {
          "cwd": "${workspaceFolder:🧪 Tests (Playwright + Cucumber BDD)}",
        },
        "group": "test",
        "presentation": { "reveal": "always", "panel": "new" },
      },
      {
        "label": "🔍 TypeScript: Check All",
        "type": "shell",
        "command": "npx tsc --noEmit",
        "options": {
          "cwd": "${workspaceFolder:🖥  Backend (Express + TypeScript + SQLite)}",
        },
        "group": "build",
        "presentation": { "reveal": "always", "panel": "shared" },
      },
    ],
  },
}
